ENV=dev
LOG_LEVEL=INFO

# Infisical project selection 
INFISICAL_PROJECT_ID=a959a649-7d10-409f-aa68-a2379adfdb90
INFISICAL_SECRET_ENV=dev

# AWS / SQS — local ElasticMQ via dev-tmux (override via Infisical / env in prod).
AWS_ENDPOINT_URL=http://localhost:9324
AWS_SQS_QUEUE_URL=http://localhost:9324/000000000000/engine-jobs.fifo
AWS_REGION=elasticmq
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test


# Backend the engine calls back into. Must match BACKEND_SECRET in backend/.env.
BACKEND_URL=http://localhost:8000
BACKEND_SECRET=dev-shared-secret-do-not-use-in-prod
